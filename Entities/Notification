{
  "name": "Notification",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string",
      "description": "Email of the recipient"
    },
    "type": {
      "type": "string",
      "enum": [
        "rating",
        "comment",
        "expert_review",
        "trending",
        "reminder",
        "system"
      ],
      "description": "Notification type"
    },
    "title": {
      "type": "string",
      "description": "Notification title"
    },
    "message": {
      "type": "string",
      "description": "Notification body"
    },
    "post_id": {
      "type": "string",
      "description": "Related post ID if applicable"
    },
    "is_read": {
      "type": "boolean",
      "description": "Whether the notification has been read"
    }
  },
  "required": [
    "user_email",
    "type",
    "title",
    "message"
  ]
}